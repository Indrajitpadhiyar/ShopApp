{
  "expo": {
    "name": "LuckyElectrical",
    "slug": "lucky-electrical",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/LEH_Logo.png",
    "scheme": "lucky-electrical",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.indrajitpadhiyar.luckyelectrical"
    },

    "android": {
      "package": "com.indrajitpadhiyar.luckyelectrical",
      "versionCode": 2,

      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",

          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "62fd9479-5d57-4cbf-8d09-8fdb2c9c4f60"
      }
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    }
  }
}